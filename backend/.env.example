# =============================================
# TriDéchet Backend — Variables d'environnement
# =============================================
# Copier ce fichier en .env et remplir les valeurs
# ATTENTION: Ne jamais committer le fichier .env !

# --- JWT Security ---
# Générer avec: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change_me_to_a_random_secret_key_at_least_32_chars
REFRESH_SECRET_KEY=change_me_to_another_random_secret_key_at_least_32_chars

# --- Google OAuth2 ---
# Obtenir sur: https://console.cloud.google.com/
GOOGLE_CLIENT_ID=your_google_client_id_here.apps.googleusercontent.com

# --- Email (optionnel, pour OTP) ---
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your_email@gmail.com
# SMTP_PASSWORD=your_app_password

# --- Base de données ---
# Par défaut SQLite (sql_app.db) - pour prod utiliser PostgreSQL
# DATABASE_URL=postgresql://user:password@localhost/tridechet
